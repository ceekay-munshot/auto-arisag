  "acma": {
    "source_name": "ACMA",
    "period_label": "FY2024-25",
    "release_date": "2025-07-08",
    "source_url": "https://www.acma.in/uploads/press-release/Press%20Release%20FY25.pdf",
    "headline": "Indian auto component industry clocks turnover of Rs 6.73 lakh crore in FY25.",
    "metrics": [
      {
        "label": "Industry turnover",
        "value": "Rs 6.73 lakh crore",
        "delta": "+9.6% YoY"
      },
      {
        "label": "OEM supplies",
        "value": "Rs 5.70 lakh crore",
        "delta": "+10% YoY"
      },
      {
        "label": "Exports",
        "value": "USD 22.9 billion",
        "delta": "+8.0% YoY"
      },
      {
        "label": "Imports",
        "value": "USD 22.4 billion",
        "delta": "+7.3% YoY"
      },
      {
        "label": "Trade surplus",
        "value": "USD 453 million",
        "delta": "vs USD 300 million in FY24"
      },
      {
        "label": "Aftermarket",
        "value": "Rs 99,948 crore",
        "delta": "+6% YoY"
      }
    ],
    "insights": [
      "Domestic OEM demand remained the largest growth driver, supported by about 8% growth in vehicle production.",
      "Exports stayed healthy despite geopolitical disruptions, with North America still the largest market and Asia the fastest-growing region.",
      "Aftermarket demand stayed firm on a larger used-vehicle base, formalisation of repairs, and rising e-commerce penetration.",
      "ACMA specifically flags rare-earth magnet availability as a strategic watchpoint for EV and mobility manufacturing."
    ],
    "scope_note": "ACMA notes that tyres, batteries, paints and consumables are excluded from industry scope; EV component sales to domestic OEMs are included under OEM supply figures, excluding batteries."
  }
